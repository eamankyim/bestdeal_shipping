# Server Configuration
PORT=5000
NODE_ENV=development
API_URL=http://localhost:5000
# For production, Vercel provides VERCEL_URL automatically
# Or set manually: PRODUCTION_URL=https://your-backend.vercel.app

# Database Configuration (Prisma Postgres from Vercel)
# Get these from Vercel Prisma integration
POSTGRES_URL="your-postgres-url-here"
PRISMA_DATABASE_URL="your-prisma-accelerate-url-here"
DATABASE_URL="your-database-url-here"

# JWT Configuration
# IMPORTANT: Generate strong secrets for production!
# Generate using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Frontend URL (for invitation links)
# Production: https://bestdealshippingapp.com
# Development: http://localhost:3000
FRONTEND_URL=http://localhost:3000

# SMTP Email Delivery
# Gmail requires an App Password, not the regular account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=BestDeal Shipping
# Optional: override the full From header
# SMTP_FROM="BestDeal Shipping <your-email@example.com>"
# Optional for npm run smtp:verify; sends a test only when set
# SMTP_TEST_TO=recipient@example.com

# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# File Upload Configuration
MAX_FILE_SIZE=5242880
UPLOAD_DIR=./uploads

# Rate Limiting (per IP per window; development uses higher default in code)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100
